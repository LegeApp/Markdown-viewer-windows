<Window x:Class="MarkdownViewer.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MarkdownViewer.Wpf.Views"
        Title="Markdown Viewer"
        Height="900"
        Width="1400"
        MinHeight="700"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Command="{Binding OpenFileCommand}"/>
                <MenuItem Header="_Reload" Command="{Binding ReloadCommand}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle _Theme" Command="{Binding ToggleThemeCommand}"/>
            </MenuItem>
        </Menu>
        
        <views:MainView Grid.Row="1"/>
    </Grid>
</Window>
